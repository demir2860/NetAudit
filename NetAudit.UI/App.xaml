<Application x:Class="NetAudit.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="Primary">#1976D2</Color>
        <Color x:Key="Success">#4CAF50</Color>
        <Color x:Key="Warning">#FF9800</Color>
        <Color x:Key="Error">#F44336</Color>
        <Color x:Key="Background">#F5F7FA</Color>
        <Color x:Key="CardBackground">#FFFFFF</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1976D2"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FA"/>
    </Application.Resources>
</Application>
