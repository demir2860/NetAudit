<Window x:Class="NetAudit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetAudit Pro - Wireshark" Height="800" Width="1400"
        Background="#F5F7FA" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="11">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox x:Name="DeviceSelector" Width="300" Padding="8" Margin="0,0,10,0"/>
                <Button x:Name="BtnStart" Content="▶ Start" Padding="12,6" Background="#4CAF50" Foreground="White" Click="OnStartCapture"/>
                <Button x:Name="BtnStop" Content="⏹ Stop" Padding="12,6" Margin="5,0,0,0" Background="#F44336" Foreground="White" Click="OnStopCapture"/>
                <Button x:Name="BtnClear" Content="Clear" Padding="12,6" Margin="5,0,0,0" Background="#999" Foreground="White" Click="OnClearPackets"/>
                <Separator Width="1" Background="#DDD" Margin="10,0"/>
                <TextBox x:Name="FilterBox" Width="150" Padding="6" Margin="0,0,5,0"/>
                <Button Content="Filter" Padding="12,6" Background="#1976D2" Foreground="White" Click="OnApplyFilter"/>
                <TextBlock x:Name="PacketCount" Text="Packets: 0" Margin="20,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- PACKET LIST -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <DataGrid x:Name="PacketGrid" AutoGenerateColumns="False" GridLinesVisibility="All">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No." Binding="{Binding No}" Width="50"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80"/>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120"/>
                    <DataGridTextColumn Header="Destination" Binding="{Binding Destination}" Width="120"/>
                    <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="70"/>
                    <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="70"/>
                    <DataGridTextColumn Header="Info" Binding="{Binding Info}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- SPLITTER -->
        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="#DDD" Cursor="SizeNS"/>

        <!-- PACKET DETAILS -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBox x:Name="DetailView" IsReadOnly="True" Background="White" Foreground="#333"
                     FontFamily="Courier New" FontSize="10" TextWrapping="Wrap" Padding="10" Margin="0"/>
        </Border>
    </Grid>
</Window>
