<Window x:Class="NetAudit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetAudit Pro v4" Height="900" Width="1400"
        Background="#F5F7FA" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel>
                <Border Background="#1976D2" Padding="16,20">
                    <StackPanel>
                        <TextBlock Text="NETAUDIT" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Pro v4" FontSize="10" Foreground="#B3E5FC" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,10,0,0">
                    <Button x:Name="BtnNetworkScan" Content="🌐 Network Scan" Padding="12,10"
                            Background="Transparent" HorizontalAlignment="Stretch"
                            BorderThickness="0" Foreground="#333" Click="OnMenuClick"/>
                    <Button x:Name="BtnServerScan" Content="🖥️ Server Scan" Padding="12,10"
                            Background="Transparent" HorizontalAlignment="Stretch"
                            BorderThickness="0" Foreground="#333" Click="OnMenuClick"/>
                    <Button x:Name="BtnSwitchScan" Content="🔀 Switch Scan" Padding="12,10"
                            Background="Transparent" HorizontalAlignment="Stretch"
                            BorderThickness="0" Foreground="#333" Click="OnMenuClick"/>
                    <Button x:Name="BtnReports" Content="📊 Reports" Padding="12,10"
                            Background="Transparent" HorizontalAlignment="Stretch"
                            BorderThickness="0" Foreground="#333" Click="OnMenuClick"/>
                </StackPanel>

                <Border Height="1" Background="#E0E0E0" Margin="0,20,0,20"/>

                <Border Padding="12" Background="#E3F2FD" Margin="8">
                    <StackPanel>
                        <TextBlock Text="Last Scan" FontSize="11" Foreground="#1976D2" FontWeight="Bold"/>
                        <TextBlock x:Name="LastScanTime" Text="Never" FontSize="10" Foreground="#555" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,0">
                <TextBlock Text="NetAudit Pro" FontSize="20" FontWeight="Bold"
                           Foreground="#333" VerticalAlignment="Center"/>
            </Border>

            <!-- DASHBOARD -->
            <Grid Grid.Row="1" Margin="20">
                <StackPanel VerticalAlignment="Top">
                    <!-- Summary Cards -->
                    <TextBlock Text="System Status" FontSize="16" FontWeight="Bold"
                               Foreground="#333" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0"
                                BorderThickness="1" Padding="16" Margin="0,0,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🖥️ Total" FontSize="12" Foreground="#999" TextAlignment="Center"/>
                                <TextBlock Text="0" FontSize="32" FontWeight="Bold" Foreground="#1976D2" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0"
                                BorderThickness="1" Padding="16" Margin="0,0,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✓ Healthy" FontSize="12" Foreground="#999" TextAlignment="Center"/>
                                <TextBlock Text="0" FontSize="32" FontWeight="Bold" Foreground="#4CAF50" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0"
                                BorderThickness="1" Padding="16" Margin="0,0,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⚠ Warning" FontSize="12" Foreground="#999" TextAlignment="Center"/>
                                <TextBlock Text="0" FontSize="32" FontWeight="Bold" Foreground="#FF9800" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="White" BorderBrush="#E0E0E0"
                                BorderThickness="1" Padding="16">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✗ Critical" FontSize="12" Foreground="#999" TextAlignment="Center"/>
                                <TextBlock Text="0" FontSize="32" FontWeight="Bold" Foreground="#F44336" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Status Message -->
                    <TextBlock x:Name="StatusMessage" Text="Ready" FontSize="14" Foreground="#666"
                               Margin="0,20,0,10"/>

                    <!-- Action Button -->
                    <Button x:Name="BtnStartScan" Content="▶️ Start Scan" Padding="20,10"
                            Background="#1976D2" Foreground="White" Width="150"
                            Click="OnStartScanClick"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
